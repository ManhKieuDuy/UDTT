#include <iostream>
using namespace std;

int x[100];
int n;
//Dao gia trị hai phan tu
void swap(int& a, int& b) {
    int tg = a;
    a = b;
    b = tg;
}

//Hien thi mot cau hinh
void view_config(int x[], int n) {
    for (int i = 1; i <= n; i++)
        cout << x[i];
    cout << endl;
}

//Sinh cau hinh moi tu cau hinh dang co
void next_config(int x[], int n, int i) {
    //Tim x[k] be nhat trong doan cuoi lớn hon x[i]
    int k = n;
    while (x[k] < x[i]) {
        k--;
    }
    //Dao gia tri x[i] va x[k]
    swap(x[i], x[k]);
    //Dao nguoc doan cuoi
    int j = n; i++;
    while (i < j) {
        swap(x[i], x[j]); i++; j--;
    }
}

//Liet ke cac cau hinh
void listing_configs(int n) {
    int i, x[100] = { 0 };
    for (i = 1; i <= n; i++) { x[i] = i; }
    do {
        view_config(x, n);
        i = n - 1;
        while (i > 0 && x[i] > x[i + 1]) i--;
        if (i > 0) {
            next_config(x, n, i);
        }
    } while (i > 0);
}
int main()
{
    int n;
    cout << "Nhap n (do dai hoan vi): ";
    cin >> n;

    if (n <= 0 || n > 100) {
        cout << "Vui long nhap 0 < n < 100" << endl;
        return 0;
    }

    cout << "Cac hoan vi cua tap tu 1 den " << n << " la:" << endl;
    listing_configs(n);

    return 0;
}
