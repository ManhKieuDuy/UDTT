#include <iostream>

using namespace std;

int n;
int a[100];
int dd[100];

void show(int a[]) {
    for (int i = 1; i <= n; i++) {
        cout << a[i];
    }
    cout << endl;
}
void Try(int k) {
    for (int i = 1; i <= n; i++) {
        if (dd[i] == 0) {
            a[k] = i;
            if (k == n) {
                show(a);
            }
            else {
                dd[i] = 1;
                Try(k + 1);
                dd[i] = 0;
            }
        }
    }
}
int main()
{
    cout << "Liet ke cac hoan vi cua tap S = {1, 2, 3, ... n} voi n = ";
    cin >> n;
    Try(1);
    return 0;
}
