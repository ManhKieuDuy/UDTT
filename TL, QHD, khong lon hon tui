#include <iostream>
#include <algorithm>
#include <string>
#include <vector>
#include <iomanip>

using namespace std;
struct GiaoVien{
    string hoTen;
    int soLopHoc;
    float luongThang;
};

vector<GiaoVien> d{
    {"Kieu Duy Manh", 4, 13},
    {"Nguyen Duy", 3, 11},
    {"Nguyen Minh Tuan", 5, 9},
    {"Nguyen Ngoc Tien", 5, 8},
    {"Phan Huy Dung", 2, 7},
    {"Hoang Truong", 6, 6},
    {"Nguyen Anh Long", 7, 6},
    {"Kieu Thi Trang", 3, 5},
    {"Kieu Viet Tu", 4, 4},
};
int m = 30;
int n = d.size();
int F[100][100];

void mySort(vector<GiaoVien>& d){
    for(int i = 0; i < d.size() - 1; i++){
        for(int j = i + 1; j < d.size(); j++){
            if(d[i].luongThang > d[j].luongThang){
                swap(d[i], d[j]);
            }
        }
    }
}

void G(vector<GiaoVien>& d, vector<GiaoVien>& kq, float m){
    kq.clear();
    float tongLuongHienTai = 0;

    for(int i = 0; i < d.size(); i++){
        if(tongLuongHienTai + d[i].luongThang <= m){
            kq.push_back(d[i]);
            tongLuongHienTai += d[i].luongThang;
        }
    }
}

void A(){
    for(int j = 0; j <= m; j++){
        F[0][j] = 0;
    }

    for(int i = 1; i <= n; i++){
        for(int j = 0; j <= m; j++){
            F[i][j] = F[i - 1][j];

            int luongThang_i = d[i - 1].luongThang;
            int soLopHoc_i = d[i - 1].soLopHoc;

            if(luongThang_i <= j){
                int temp = d[i - 1].soLopHoc + F[i - 1][j - luongThang_i];
                if(F[i][j] < temp){
                    F[i][j] = temp;
                }
            }
        }
    }

    cout << "Tong so lop hoc lon nhat t = " << F[n][m] << " lop." << endl;
    cout << "Nhung giao vien da chon: " << endl;
    int i = n;
    int j = m;
    while(i != 0){
        if(F[i][j] != F[i - 1][j]){
            cout << "- " << d[i - 1].hoTen << ": " << "\tso lop day: " << d[i - 1].soLopHoc << "\t| Luong thang: " << d[i - 1].luongThang << " trieu VND" <<endl;
            j = j - d[i - 1].luongThang;
        }
        i--;
    }
}

void printTable() {
    cout << "\nBANG PHUONG AN F[i][j]:" << endl;
    cout << string(60, '-') << endl;

    cout << "i\\j | ";
    for (int j = 0; j <= m; j++) {
        cout << setw(5) << j;
    }
    cout << endl << string(60, '-') << endl;

    for (int i = 0; i <= n; i++) {
        cout << setw(3) << i << " | ";
        for (int j = 0; j <= m; j++) {
            cout << setw(5) << F[i][j];
        }
        cout << endl;
    }
    cout << string(60, '-') << endl;
}

int main()
{
    cout << "THAM LAM: " << endl;
    vector<GiaoVien> kq;
    mySort(d);
    G(d, kq, m);
    float tongLuongKQ = 0, count = 0;
    for(int i = 0; i < kq.size(); i++){
        tongLuongKQ += kq[i].luongThang;
    }
    cout << "So giao vien lon nhat can chon tu ds d, u = " << kq.size() << endl;
    cout << "sao cho tong luong thang v khong lon hon m, v = " << tongLuongKQ << " trieu VND" << endl;

    cout << "\nQUY HOACH DONG:" << endl;
    A();
    printTable();
    return 0;
}
