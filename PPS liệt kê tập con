#include <iostream>
using namespace std;

int x[100];
int k, n;

//Sinh cau hinh moi tu cau hinh dang co
void next_config(int x[], int k, int i) {
    x[i] += 1;
    i++;
    while (i <= k) {
        x[i] = x[i - 1] + 1;
        i++;
    }
}
//Hien thi mot cau hinh
void view_config(int x[], int k) {
    for (int i = 1; i <= k; i++)
        cout << x[i];
    cout << endl;
}

void listing_configs(int k, int n) {
    int i, x[100] = { 0 };
    for (i = 1; i <= k; i++) { x[i] = i; }
    do {
        view_config(x, k);
        i = k;
        while (i > 0 && x[i] == n - k + i)
            i--;
        if (i > 0) { 
            next_config(x, k, i);
        }
    } while (i > 0);
}
int main()
{
    cout << "Nhap n (tong so phan tu): ";
    cin >> n;
    cout << "Nhap k (so phan tu tap con): ";
    cin >> k;

    if (k > n || k < 0) {
        cout << "Dieu kien khong hop le (k phai <= n va k >= 0)" << endl;
        return 0;
    }

    if (k == 0) {
        cout << "Tap con rong" << endl;
        return 0;
    }

    cout << "Cac tap con " << k << " phan tu cua tap " << n << " phan tu la:" << endl;
    listing_configs(k, n);

    return 0;
}
